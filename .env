APP_ENV=dev
PORT=3000
COOKIE_SECRET=supersecretcookiesecret123
SUPERADMIN_USERNAME=superadmin
SUPERADMIN_PASSWORD=superadmin

# ═══════════════════════════════════════════════════════════════
# Network binding & CORS (for cross-server deployment)
# ═══════════════════════════════════════════════════════════════
# Bind address: 0.0.0.0 = listen on all interfaces (required for other servers to connect)
# Override with 127.0.0.1 if you want loopback-only.

# CORS origins: comma-separated list of frontend URLs allowed to call this Vendure backend.
# Local dev:
#
# Cross-server example (replace with the storefront's actual URL):
# CORS_ORIGIN=http://localhost:3001,http://192.168.1.20:3001,https://pos.yourdomain.com
