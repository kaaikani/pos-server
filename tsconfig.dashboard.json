{
  "compilerOptions": {
    "composite": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": false,
    "noImplicitAny": false,
    "skipLibCheck": true,
    "types": [],
    "paths": {
      "@/gql": [
        "./src/gql/graphql.js"
      ],
      "@/vdb/*": [
        "./node_modules/@vendure/dashboard/src/lib/*"
      ]
    }
  },
  "include": [
    "src/plugins/**/dashboard/*",
    "src/gql/**/*.js",
    "vite.*.*ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
