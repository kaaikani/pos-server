APP_ENV=dev
PORT=3000

# ── Database (defaults match local MySQL on Windows) ──
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=change-me
DB_NAME=wow_vendurepos

# Generate with: openssl rand -hex 32
COOKIE_SECRET=replace-with-random-64-hex-chars
JWT_SECRET=replace-with-random-64-hex-chars

# Superadmin credentials (change before first run)
SUPERADMIN_USERNAME=superadmin
SUPERADMIN_PASSWORD=change-me

# Initial password for the first POS admin user (auto-created on fresh install
# if no POS admin exists). Required by PosAuthService.ensureAdminExists().
POS_ADMIN_INITIAL_PASSWORD=Admin@123

# Network
HOSTNAME=
CORS_ORIGIN=http://localhost:3002,http://127.0.0.1:3002

# URLs
STOREFRONT_URL=http://localhost:3002
# ASSET_URL_PREFIX=https://cdn.yourdomain.com/assets/
